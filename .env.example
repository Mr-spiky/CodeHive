# ============================================================
# CODEHIVE — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values.
# Never commit your actual .env file to version control.
# ============================================================

# ─── AI Code Generator (Optional) ────────────────────────────
# Required only for the /[projectId] AI code generation feature.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ─── Database (Optional) ─────────────────────────────────────
# Used by the uigen (AI generator) feature via Prisma.
# Not needed if you are only running the CodeHive community pages.
# DATABASE_URL="file:./dev.db"
